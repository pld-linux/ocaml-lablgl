 Togl/src/Togl/gears.c   |  4 +-
 Togl/src/Togl/stereo.c  | 10 ++---
 Togl/src/Togl/texture.c | 22 +++++------
 Togl/src/Togl/togl.c    | 81 ++++++++++++++++++++---------------------
 Togl/src/Togl/togl.h    |  6 +--
 6 files changed, 61 insertions(+), 66 deletions(-)

